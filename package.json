{
  "name": "blogsareback",
  "version": "0.1.4",
  "description": "Blogs Are Back — Desktop App",
  "author": {
    "name": "Blogs Are Back",
    "email": "app@blogsareback.com"
  },
  "license": "AGPL-3.0-only",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"tsc --watch --preserveWatchOutput\" \"electronmon dist/main/index.js\"",
    "build": "tsc",
    "start": "electron dist/main/index.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "npm run sentry:sourcemaps && electron-builder --mac --arch=arm64",
    "dist:mac:universal": "npm run sentry:sourcemaps && electron-builder --mac --arch=universal",
    "dist:win": "npm run sentry:sourcemaps && electron-builder --win",
    "dist:linux": "npm run sentry:sourcemaps && electron-builder --linux",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload --release=blogsareback@$npm_package_version ./dist"
  },
  "build": {
    "appId": "com.blogsareback.desktop",
    "productName": "Blogs Are Back",
    "artifactName": "${productName}-v${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "assets/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        },
        {
          "target": "zip",
          "arch": "universal"
        }
      ],
      "category": "public.app-category.news",
      "icon": "assets/icon.icns",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "hardenedRuntime": true
    },
    "dmg": {
      "title": "Blogs Are Back"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network;Feed",
      "mimeTypes": [
        "x-scheme-handler/blogsareback"
      ]
    },
    "protocols": [
      {
        "name": "Blogs Are Back",
        "schemes": [
          "blogsareback"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "blogsareback",
      "repo": "desktop"
    }
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@sentry/electron": "^7.9.0",
    "edge-tts-universal": "^1.4.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "linkedom": "^0.18.0"
  },
  "devDependencies": {
    "@sentry/cli": "^3.3.0",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0"
  }
}
